# =========================
# 1. 基础依赖与锁文件 (你已有的)
# =========================
node_modules/
pnpm-lock.yaml
# 预防未来手误用错包管理器产生的锁文件
package-lock.json
yarn.lock

# =========================
# 2. 编译与构建产物 (极其重要)
# =========================
dist/
build/
.next/        # Next.js 的默认构建缓存和输出目录 (必加！)
out/          # Next.js 静态导出 (Static Export) 的默认目录

# =========================
# 3. 缓存与云端部署工具
# =========================
.vercel/      # 如果你部署到 Vercel 产生的本地缓存
.turbo/       # 如果你未来引入 Turborepo 管理 Monorepo 的缓存目录

# =========================
# 4. 环境变量与日志
# =========================
.env
.env.*
*.log
npm-debug.log*
pnpm-debug.log*

# =========================
# 5. 测试与公共资源
# =========================
coverage/     # 单元测试覆盖率报告目录
public/**/*.min.js # 如果你在 public 放了压缩过的第三方 JS
public/**/*.min.css